{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/stripe-webhook",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
